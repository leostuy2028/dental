.*
!.gitattributes

# Data parquets ARE committed for provenance/reproducibility (HuggingFace may not persist
# the source forever). The two large source files (closed_ended, open_ended) are stored via
# Git LFS (see .gitattributes); the derived clean/shuffled sets go as normal git blobs.
# The HuggingFace download cache dir (data/OralGPT___mm_oral-opg-bench) stays ignored.
data/*
!data/*.parquet

__pycache__/
*.pyc
*.log

# Results ARE committed on purpose: they come from paid API experiments and must not
# be regenerated. Keep result files descriptively named (model / config / n).
# Only exception — never publish quarantined INVALID data (hand-fabricated /
# coordinate-forced inputs); kept local for audit.
results/open/DISCARDED_invalid/
eval_open/predictions.parquet

# Private research notes — must never be published to the public GitHub mirror.
dental_research/
RESEARCH_PLAN.md
*RESEARCH_PLAN*
results/progress.txt

# transient run artifacts
results/progress_gpt.txt
results/closed_ended/reproduction/repro.pid

results/closed_ended/prompt_axis/*.log
results/closed_ended/prompt_axis/coax.pid
